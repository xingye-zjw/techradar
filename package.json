{
  "name": "techradar",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "tsx scripts/prebuild-search-index.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint \"{app,components,lib,__tests__}/**/*.{ts,tsx,js,jsx}\"",
    "format": "prettier --write .",
    "lint:ci": "eslint --max-warnings 100 \"{app,components,lib,__tests__}/**/*.{ts,tsx,js,jsx}\"",
    "audit:dep": "npm audit --audit-level=high",
    "validate-content": "npx tsx scripts/validate-content.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "dependencies": {
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@xyflow/react": "^12.11.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dagre": "^0.8.5",
    "fuse.js": "^7.4.2",
    "gray-matter": "^4.0.3",
    "next": "^14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^16.2.10",
    "@types/dagre": "^0.7.54",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "eslint-config-prettier": "*",
    "eslint-plugin-prettier": "*",
    "husky": "^9.1.7",
    "jsdom": "^24.1.3",
    "lint-staged": "*",
    "postcss": "^8.4.38",
    "prettier": "*",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.9",
    "zod": "*"
  }
}
