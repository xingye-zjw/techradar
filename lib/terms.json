      "relatedNodes": ["cv-detection"]
    },
    {
      "term": "ResNet",
      "explanation": "残差网络（Residual Network），通过跳跃连接解决深层网络的梯度消失问题。",
      "link": "https://arxiv.org/abs/1512.03385",
      "relatedNodes": ["cv-cnn"]
    },
    {
      "term": "Epoch",
