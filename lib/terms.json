    {
      "term": "CNN",
      "explanation": "卷积神经网络（Convolutional Neural Network），专门用于处理网格状数据（如图像），通过卷积层提取特征。",
      "link": "https://cs231n.github.io/convolutional-networks/",
      "relatedNodes": ["cv-cnn"]
    },
    {
      "term": "RNN",
      "explanation": "循环神经网络（Recurrent Neural Network），处理序列数据，具有记忆能力，但存在梯度消失问题。",
      "link": "https://colah.github.io/posts/2015-08-Understanding-LSTMs/",
      "relatedNodes": ["nlp-rnn"]
    },
    {
      "term": "Transformer",
      "explanation": "基于自注意力机制的架构，解决了 RNN 的并行计算问题，是 BERT、GPT 等模型的基础。",
      "link": "https://arxiv.org/abs/1706.03762",
      "relatedNodes": ["nlp-transformer"]
    },
    {
      "term": "PyTorch",
      "explanation": "Facebook 开发的深度学习框架，以动态计算图和易用性著称，适合研究和生产。",
      "link": "https://pytorch.org/tutorials/",
      "relatedNodes": ["pytorch-core"]
    },
    {
      "term": "LoRA",
      "explanation": "低秩适应（Low-Rank Adaptation），一种高效的微调方法，通过添加低秩矩阵减少参数量。",
      "link": "https://arxiv.org/abs/2106.09685",
      "relatedNodes": ["llm-finetune"]
    },
    {
      "term": "RAG",
      "explanation": "检索增强生成（Retrieval-Augmented Generation），结合检索和生成，提高 LLM 回答的准确性。",
      "link": "https://arxiv.org/abs/2005.11401",
      "relatedNodes": ["nlp-transformer"]
    },
    {
      "term": "RLHF",
      "explanation": "基于人类反馈的强化学习（Reinforcement Learning from Human Feedback），用于对齐 LLM 与人类偏好。",
      "link": "https://arxiv.org/abs/2203.02155",
      "relatedNodes": ["llm-finetune"]
    },
    {
      "term": "YOLO",
      "explanation": "You Only Look Once，实时目标检测算法，将检测任务转化为回归问题，速度极快。",
